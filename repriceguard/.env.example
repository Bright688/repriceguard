# ─────────────────────────────────────────────
# RepriceGuard — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local for local dev:
#   cp .env.example .env.local

# ── App ──────────────────────────────────────
# Public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name shown in metadata
NEXT_PUBLIC_APP_NAME=RepriceGuard

# ── Etherscan API (optional) ─────────────────
# Used by /api/scan when mode=address to fetch verified source
# Get a free key at https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Rate limiting (optional, production) ─────
# Max scan requests per IP per minute (default: 10)
RATE_LIMIT_RPM=10

# ── Node ─────────────────────────────────────
NODE_ENV=development
PORT=3000
